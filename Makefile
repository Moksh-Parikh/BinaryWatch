# ============================================================================
# Project Configuration
# ============================================================================

TARGET  = main
MCU     = attiny85
F_CPU   = 8000000UL

# ============================================================================
# Tools
# ============================================================================

CC      := avr-gcc
OBJCOPY := avr-objcopy
SIZE    := avr-size

# ============================================================================
# Directories
# ============================================================================

SRC_DIR := ./src
OBJ_DIR := ./build

# ============================================================================
# Source Files
# ============================================================================

SRCS := $(shell find $(SRC_DIR) -type f -name '*.c')

OBJS := $(patsubst $(SRC_DIR)/%.c,$(OBJ_DIR)/%.o,$(SRCS))
DEPS := $(OBJS:.o=.d)

# ============================================================================
# Compiler Flags
# ============================================================================

CFLAGS := \
    -mmcu=$(MCU) \
    -DF_CPU=$(F_CPU) \
    -Os \
    -Wall \
    -Wextra \
    -std=c11 \
    -MMD \
    -MP

LDFLAGS := -mmcu=$(MCU)

# ============================================================================
# Targets
# ============================================================================

all: $(TARGET).hex

$(TARGET).elf: $(OBJS)
	$(CC) $(LDFLAGS) $^ -o $@
	$(SIZE) $@

$(TARGET).hex: $(TARGET).elf
	$(OBJCOPY) -O ihex -R .eeprom $< $@

$(TARGET).eep: $(TARGET).elf
	$(OBJCOPY) \
		-j .eeprom \
		--change-section-lma .eeprom=0 \
		-O ihex \
		$< $@

# ============================================================================
# Compilation
# ============================================================================

$(OBJ_DIR)/%.o: $(SRC_DIR)/%.c
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -MMD -MP -c $< -o $@

# ============================================================================
# Cleanup
# ============================================================================

clean:
	rm -rf $(OBJ_DIR)
	rm -f $(TARGET).elf
	rm -f $(TARGET).hex
	rm -f $(TARGET).eep

# ============================================================================
# Dependencies
# ============================================================================

-include $(DEPS)

.PHONY: all flash clean
